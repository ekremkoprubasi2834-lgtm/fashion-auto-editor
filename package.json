{
  "name": "fashion-auto-editor",
  "version": "0.1.0",
  "description": "Local TypeScript CLI for generating fashion video editing assets from a transcript.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "start": "node dist/cli.js",
    "assets:queries": "tsx src/cli.ts assets:queries",
    "assets:audit": "tsx src/cli.ts assets:audit",
    "assets:prepare": "tsx src/cli.ts assets:prepare",
    "pinterest:auth": "tsx src/cli.ts pinterest:auth",
    "pinterest:boards": "tsx src/cli.ts pinterest:boards",
    "pinterest:collect": "tsx src/cli.ts pinterest:collect",
    "moodboard:links": "tsx src/cli.ts moodboard:links",
    "moodboard:collect": "tsx src/cli.ts moodboard:collect",
    "moodboard:review": "tsx src/cli.ts moodboard:review",
    "moodboard:approve": "tsx src/cli.ts moodboard:approve",
    "moodboard:score": "tsx src/cli.ts moodboard:score"
  },
  "dependencies": {
    "playwright": "^1.44.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
