# Uses input/voiceover.mp3 first when OpenAI transcription is configured.
# Falls back to input/transcript.txt when voiceover or API key is missing.
INPUT_TRANSCRIPT_PATH=input/transcript.txt
INPUT_VOICEOVER_PATH=input/voiceover.mp3
OUTPUT_DIR=output
OPENAI_API_KEY=
TRANSCRIPTION_PROVIDER=openai
TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
