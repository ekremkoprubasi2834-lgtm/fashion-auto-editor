# Uses input/voiceover.mp3 first when OpenAI transcription is configured.
# Falls back to input/transcript.txt when voiceover or API key is missing.
INPUT_TRANSCRIPT_PATH=input/transcript.txt
INPUT_VOICEOVER_PATH=input/voiceover.mp3
OUTPUT_DIR=output
OPENAI_API_KEY=
TRANSCRIPTION_PROVIDER=openai
TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Pinterest connector (Board Mode). Create an app at developers.pinterest.com,
# request scopes boards:read + pins:read (user_accounts:read optional). These are
# placeholders only — put real values in your local .env (never commit them).
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_REDIRECT_URI=http://localhost:8787/pinterest/callback
PINTEREST_ACCESS_TOKEN=
PINTEREST_REFRESH_TOKEN=
PINTEREST_API_BASE_URL=https://api.pinterest.com/v5
